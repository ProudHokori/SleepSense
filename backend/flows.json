        "func": "let d = msg.payload;\n\nmsg.topic = `\nINSERT INTO SleepSense\n(device_id, temp_c, hum_pct, light_lux, snd_avg, snd_peak, snd_var, snd_evt, pm1, pm25, pm10)\nVALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n`;\n\nmsg.payload = [\n    d.device_id,\n    d.temp_c,\n    d.hum_pct,\n    d.light_lux,\n    d.snd_avg,\n    d.snd_peak,\n    d.snd_var,\n    d.snd_evt,\n    d.pm1,\n    d.pm25,\n    d.pm10\n];\n\nreturn msg;",
