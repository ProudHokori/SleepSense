        "format": "<style>\n/* ===== page ===== */\nhtml, body,\nbody,\n.nr-dashboard-theme,\nmd-content,\nmd-content.md-default-theme {\n    background: linear-gradient(180deg, #faf6fc 0%, #f5f0f9 100%) !important;\n    font-family: \"Segoe UI\", \"Noto Sans Thai\", sans-serif !important;\n    color: #3f3650 !important;\n}\n\n/* ===== top bar ===== */\nmd-toolbar {\n    background: linear-gradient(90deg, #b8a2d6, #aa94cb) !important;\n    color: #fff !important;\n    box-shadow: 0 2px 10px rgba(120, 95, 150, 0.10) !important;\n}\n\nmd-toolbar .md-toolbar-tools {\n    font-size: 18px !important;\n    font-weight: 600 !important;\n    letter-spacing: 0.1px;\n}\n\n/* ===== overall spacing ===== */\n.nr-dashboard-theme .layout-row > .flex {\n    padding: 5px !important;\n}\n\n/* ===== group panels ===== */\n.nr-dashboard-cardpanel {\n    background: rgba(255,255,255,0.88) !important;\n    border: 1px solid #eadff2 !important;\n    border-radius: 14px !important;   /* แก้โค้ง */\n    box-shadow: 0 3px 10px rgba(110, 90, 145, 0.06) !important;\n    min-height: 100% !important;\n    overflow: hidden !important;\n    backdrop-filter: none !important;\n    -webkit-backdrop-filter: none !important;\n}\n\n/* ===== group title ===== */\n.nr-dashboard-cardtitle {\n    color: #5e4b73 !important;\n    font-size: 17px !important;\n    font-weight: 700 !important;\n    text-align: center !important;\n    padding: 10px 8px 10px 8px !important;\n    line-height: 1.3 !important;\n}\n\n/* ===== summary side ===== */\n.nr-dashboard-text {\n    background: transparent !important;\n    padding: 2px 6px !important;\n    border-radius: 8px !important;\n}\n\n.nr-dashboard-text p,\n.nr-dashboard-text span,\n.nr-dashboard-text div {\n    color: #3f3650 !important;\n    font-size: 14px !important;\n    line-height: 1.35 !important;\n}\n\n/* ===== charts ===== */\n.nr-dashboard-chart {\n    background: #fffdfe !important;\n    border: 1px solid #eee4f4 !important;\n    border-radius: 12px !important;   /* แก้โค้ง */\n    padding: 4px !important;\n    box-shadow: none !important;\n    overflow: hidden !important;\n}\n\n/* chart text */\n.nr-dashboard-chart text,\nsvg text {\n    fill: #6d607f !important;\n    font-size: 11px !important;\n}\n\n/* chart title */\n.nr-dashboard-chart-title,\n.nr-dashboard-chart .nr-dashboard-chart-title {\n    font-size: 14px !important;\n    font-weight: 600 !important;\n    color: #4f435f !important;\n}\n\n/* ===== make it feel like one screen ===== */\n.nr-dashboard-cardpanel {\n    min-height: 100% !important;\n}\n\n/* ===== subtle hover ===== */\n.nr-dashboard-cardpanel:hover,\n.nr-dashboard-chart:hover {\n    box-shadow: 0 6px 16px rgba(110, 90, 145, 0.08) !important;\n    transition: all 0.2s ease;\n}\n\n/* ===== internal cards ===== */\nmd-card {\n    border-radius: 10px !important;\n    box-shadow: none !important;\n}\n\n/* ===== scrollbar ===== */\n::-webkit-scrollbar {\n    width: 10px;\n}\n::-webkit-scrollbar-thumb {\n    background: #d7cae6;\n    border-radius: 999px;\n}\n::-webkit-scrollbar-track {\n    background: transparent;\n}\n\n/* ===== center whole dashboard on wide screen ===== */\n@media (min-width: 1300px) {\n    .nr-dashboard-theme {\n        max-width: 1780px;\n        margin: 0 auto;\n    }\n}\n</style>",
