        "name": "api formatter",
        "func": "const rows = msg.payload;\n\n// ตรวจสอบว่ามีข้อมูลไหม\nif (!rows || rows.length === 0) {\n    msg.payload = { message: \"No data found\" };\n    return msg;\n}\n\nconst formattedData = rows.map(row => ({\n    \"id\": row.id,\n    \"timestamp\": row.timestamp,\n    \"factors\": {\n        \"temp_c\": row.temp_c,\n        \"hum_pct\": row.hum_pct,\n        \"light_lux\": row.light_lux,\n        \"snd_avg\": row.snd_avg,\n        \"snd_peak\": row.snd_peak,\n        \"snd_var\": row.snd_var,\n        \"snd_evt\": row.snd_evt,\n        \"pm1\": row.pm1,\n        \"pm25\": row.pm25,\n        \"pm10\": row.pm10\n    },\n    \"sleep_scores\": {\n        \"linear_regression_score\": row.linear_regression_score,\n        \"ridge1_score\": row.ridge1_score,\n        \"lasso_score\": row.lasso_score,\n        \"random_forest_score\": row.random_forest_score,\n        \"gradient_boosting_score\": row.gradient_boosting_score\n    }\n}));\n\nmsg.payload = formattedData;\nreturn msg;",
