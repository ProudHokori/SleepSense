    {
        "id": "db3b35b1b5c31742",
        "type": "function",
        "z": "54995f5a8240e2ac",
        "g": "f6aba33dfbcbaf65",
        "name": "show query",
        "func": "let row = msg.payload[0];\n\nfunction formatBangkokDate(input) {\n    if (!input) return \"N/A\";\n\n    let d = new Date(input);\n    if (isNaN(d.getTime())) return \"N/A\";\n\n    let formatter = new Intl.DateTimeFormat(\"en-GB\", {\n        timeZone: \"Asia/Bangkok\",\n        day: \"2-digit\",\n        month: \"long\",\n        year: \"numeric\",\n        hour: \"2-digit\",\n        minute: \"2-digit\",\n        second: \"2-digit\",\n        hour12: false\n    });\n\n    let parts = formatter.formatToParts(d);\n    let map = {};\n    for (let p of parts) {\n        map[p.type] = p.value;\n    }\n\n    return `${map.day} ${map.month} ${map.year} ${map.hour}:${map.minute}:${map.second} Asia/Bangkok`;\n}\n\nif (!row) {\n    return new Array(15).fill({ payload: \"N/A\" });\n}\n\n\nreturn [\n    { payload: row.id || \"N/A\" },\n    { payload: formatBangkokDate(row.timestamp) },\n\n    { payload: `${row.temp_c ?? \"N/A\"} °C` },\n    { payload: `${row.hum_pct ?? \"N/A\"} %` },\n    { payload: `${row.light_lux ?? \"N/A\"} lux` },\n    { payload: `${row.snd_avg ?? \"N/A\"} dB` },\n    { payload: `${row.snd_evt ?? \"N/A\"} times` },\n    { payload: `${row.pm1 ?? \"N/A\"} µg/m³` },\n    { payload: `${row.pm25 ?? \"N/A\"} µg/m³` },\n    { payload: `${row.pm10 ?? \"N/A\"} µg/m³` },\n\n    // ----- scores -----\n    { payload: row.linear_regression_score ?? \"N/A\" },\n    { payload: row.ridge1_score ?? \"N/A\" },\n    { payload: row.lasso_score ?? \"N/A\" },\n    { payload: row.random_forest_score ?? \"N/A\" },\n    { payload: row.gradient_boosting_score ?? \"N/A\" }\n];",
        "outputs": 15,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
