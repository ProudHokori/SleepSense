        "name": "validate + prepare query",
        "func": "const query = msg.req.query || {};\n\nconst start = query.start;\nconst end = query.end;\nconst rawLimit = query.limit;\n\n// รับ format: YYYY-MM-DD HH:MM:SS\nconst dtRegex = /^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$/;\n\nfunction badRequest(message) {\n    msg.statusCode = 400;\n    msg.payload = {\n        success: false,\n        error: message\n    };\n    return [null, msg];\n}\n\nif (!start || !end) {\n    return badRequest(\"Both 'start' and 'end' query parameters are required.\");\n}\n\nif (!dtRegex.test(start) || !dtRegex.test(end)) {\n    return badRequest(\"Invalid datetime format. Use YYYY-MM-DD HH:MM:SS\");\n}\n\n// parse แบบปลอดภัยเบื้องต้น\nconst startDate = new Date(start.replace(\" \", \"T\"));\nconst endDate = new Date(end.replace(\" \", \"T\"));\n\nif (isNaN(startDate.getTime()) || isNaN(endDate.getTime())) {\n    return badRequest(\"Invalid datetime value.\");\n}\n\nif (startDate > endDate) {\n    return badRequest(\"'start' must be earlier than or equal to 'end'.\");\n}\n\n// จำกัด limit เพื่อกัน query ใหญ่เกิน\nlet limit = 1000;\nif (rawLimit !== undefined) {\n    limit = parseInt(rawLimit, 10);\n    if (isNaN(limit) || limit < 1) {\n        return badRequest(\"'limit' must be a positive integer.\");\n    }\n    if (limit > 5000) {\n        return badRequest(\"'limit' must not be greater than 5000.\");\n    }\n}\n\n// prepared query with named parameters\nmsg.topic = `\n    SELECT\n        id,\n        device_id,\n        recorded_at,\n        temp_c,\n        hum_pct,\n        light_lux,\n        snd_avg,\n        snd_evt,\n        pm1,\n        pm25,\n        pm10\n    FROM SleepSense\n    WHERE recorded_at BETWEEN :start AND :end\n    ORDER BY recorded_at ASC\n    LIMIT :limit;\n`;\n\nmsg.payload = {\n    start,\n    end,\n    limit\n};\n\n// metadata ไว้ใช้ตอบกลับ\nmsg.apiMeta = {\n    start,\n    end,\n    limit\n};\n\nreturn [msg, null];",
